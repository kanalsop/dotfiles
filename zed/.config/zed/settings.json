// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "sticky_scroll": {
    "enabled": true,
  },
  "ssh_connections": [
    {
      "host": "mirin",
      "args": [],
      "projects": [
        {
          "paths": ["/home/hirata/build-forecast/build-forecast/./"],
        },
      ],
    },
  ],
  "scrollbar": {
    "git_diff": true,
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true,
  },
  "restore_on_startup": "launchpad",
  "agent": {
    "favorite_models": [],
    "model_parameters": [],
    "expand_edit_card": true,
  },
  "disable_ai": false,
  "edit_predictions": {
    "disabled_globs": [],
  },
  "tabs": {
    "git_status": true,
  },
  "tab_bar": {
    "show": true,
  },
  "title_bar": {
    "show_user_picture": true,
    "show_menus": false,
    "show_sign_in": true,
    "show_onboarding_banner": true,
    "show_project_items": true,
    "show_branch_icon": false,
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
    },
  },
  "base_keymap": "VSCode",
  "autosave": "on_focus_change",
  "show_whitespaces": "all",
  "soft_wrap": "editor_width",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "buffer_font_fallbacks": ["Cica"],
  "buffer_font_weight": 400,
  "buffer_line_height": "comfortable",
  "buffer_font_features": {
    "calt": false,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.ruff_cache",
    "**/.uv-cache",
    "**/__pycache__",
  ],

  "terminal": {
    "dock": "right",
    "shell": "system",
    "font_family": "Hack Nerd Font Mono",
    "detect_venv": "off",
  },

  "languages": {
    "Python": {
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports.ruff": true,
      },
      "formatter": {
        "language_server": {
          "name": "ruff",
        },
      },
      "colorize_brackets": true,
    },
    "CSV": {
      "formatter": {
        "external": {
          "command": "csvfmt",
          "arguments": ["align", "--buffer-path", "{buffer_path}"],
        },
      },
    },
  },
}
