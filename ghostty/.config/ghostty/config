# フォント設定
font-family = "UbuntuMono Nerd Font"
font-size = 16

# テーマ
theme = dark:Catppuccin Mocha,light:Catppuccin Latte

# 背景の透過とブラー
background-opacity = 0.80
background-blur-radius = 20

# タイトルバーをMacネイティブ風にする
window-decoration = true
window-theme = auto

# ウィンドウの余白
window-padding-x = 12
window-padding-y = 12

# ペースト時の警告を無効にする
clipboard-paste-protection = false
